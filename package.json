{
  "name": "apple-notes-exporter",
  "version": "1.0.0",
  "description": "Export Apple Notes to various formats",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Julien Quintard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/routineco/apple-notes-exporter"
  },
  "homepage": "https://apple-notes-exporter.com",
  "keywords": [
    "apple",
    "notes",
    "routine"
  ],
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "exif-js": "^2.3.0",
    "jsdom": "^24.0.0",
    "jspdf": "^2.5.1",
    "node-html-markdown": "^1.3.0",
    "rtf-parser": "^1.3.3"
  },
  "build": {
    "appId": "co.routine.apple-notes-exporter",
    "productName": "Apple Notes Exporter",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "Routine (YMZXQGP887)",
      "notarize": true
    },
    "dmg": {
      "title": "Apple Notes Exporter"
    },
    "files": [
      "src/**/*",
      "scripts/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "scripts/**/*"
    ]
  }
}